{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "News": {
      "title": "School News",
      "description": "Latest news and events from the school",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "News title" },
        "content": { "type": "string", "description": "News content" },
        "authorUid": { "type": "string", "description": "Author user ID" },
        "imageUrl": { "type": "string", "description": "News image URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "News creation timestamp" }
      },
      "required": ["title", "content", "authorUid"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Messages sent from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "description": "Sender email" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Message timestamp" }
      },
      "required": ["name", "email", "message"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website settings and content",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The content of the setting (can be JSON string)" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["content"]
    },
    "Registration": {
      "title": "Student Registration",
      "description": "New student registration data",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the student" },
        "email": { "type": "string", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "birthDate": { "type": "string", "format": "date", "description": "Date of birth" },
        "gender": { "type": "string", "enum": ["Laki-laki", "Perempuan"], "description": "Gender" },
        "address": { "type": "string", "description": "Full address" },
        "previousSchool": { "type": "string", "description": "Previous school name" },
        "major": { "type": "string", "description": "Selected major" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"], "description": "Registration status" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "uploaded"] },
              "url": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" }
      },
      "required": ["fullName", "email", "phone", "major"]
    },
    "Major": {
      "title": "School Major",
      "description": "Information about school majors",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Major title" },
        "description": { "type": "string", "description": "Short description" },
        "longDescription": { "type": "string", "description": "Detailed description" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "color": { "type": "string", "description": "Tailwind color class" },
        "prospects": { "type": "array", "items": { "type": "string" }, "description": "Career prospects" },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Skills learned" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "longDescription"]
    },
    "Stat": {
      "title": "School Statistic",
      "description": "Key school statistics",
      "type": "object",
      "properties": {
        "label": { "type": "string", "description": "Statistic label" },
        "value": { "type": "string", "description": "Statistic value" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "color": { "type": "string", "description": "Tailwind text color class" },
        "bg": { "type": "string", "description": "Tailwind background color class" },
        "order": { "type": "integer", "description": "Display order" }
      },
      "required": ["label", "value"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Student or alumni testimonial",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Person name" },
        "role": { "type": "string", "description": "Person role/title" },
        "content": { "type": "string", "description": "Testimonial content" },
        "avatar": { "type": "string", "description": "Avatar image URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "role", "content"]
    },
    "Extracurricular": {
      "title": "Extracurricular",
      "description": "School extracurricular activities",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Activity title" },
        "description": { "type": "string", "description": "Activity description" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description"]
    },
    "Facility": {
      "title": "Facility",
      "description": "School facilities",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Facility title" },
        "description": { "type": "string", "description": "Facility description" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description"]
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Questions",
      "type": "object",
      "properties": {
        "question": { "type": "string", "description": "The question" },
        "answer": { "type": "string", "description": "The answer" },
        "order": { "type": "integer", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["question", "answer"]
    },
    "Gallery": {
      "title": "Gallery Image",
      "description": "School gallery images",
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "Image URL" },
        "caption": { "type": "string", "description": "Image caption" },
        "category": { "type": "string", "description": "Image category" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["url", "category"]
    },
    "Exam": {
      "title": "Computer Based Test",
      "description": "Stores exam information and questions",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Exam title" },
        "description": { "type": "string", "description": "Exam description" },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "startTime": { "type": "string", "format": "date-time", "description": "Start time" },
        "endTime": { "type": "string", "format": "date-time", "description": "End time" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "integer" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "duration", "startTime", "endTime"]
    },
    "ExamSession": {
      "title": "Exam Session",
      "description": "Stores student exam progress and results",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Student user ID" },
        "examId": { "type": "string", "description": "Exam ID" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ongoing", "completed"] },
        "answers": { "type": "object", "description": "Map of questionId to selected option index" },
        "score": { "type": "number" },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["uid", "examId", "status"]
    },
    "Grade": {
      "title": "Student Grade",
      "description": "Stores student selection test grades",
      "type": "object",
      "properties": {
        "math": { "type": "number" },
        "indonesian": { "type": "number" },
        "english": { "type": "number" },
        "science": { "type": "number" },
        "average": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "News and events collection"
    },
    "/messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Contact form messages"
    },
    "/settings/{settingId}": {
      "schema": "SiteSettings",
      "description": "Global website settings"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Student registration collection"
    },
    "/majors/{majorId}": {
      "schema": "Major",
      "description": "School majors collection"
    },
    "/stats/{statId}": {
      "schema": "Stat",
      "description": "School statistics collection"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Testimonials collection"
    },
    "/extracurriculars/{extraId}": {
      "schema": "Extracurricular",
      "description": "Extracurriculars collection"
    },
    "/facilities/{facilityId}": {
      "schema": "Facility",
      "description": "Facilities collection"
    },
    "/faqs/{faqId}": {
      "schema": "FAQ",
      "description": "FAQs collection"
    },
    "/gallery/{galleryId}": {
      "schema": "Gallery",
      "description": "Gallery collection"
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Exams collection"
    },
    "/exam_sessions/{sessionId}": {
      "schema": "ExamSession",
      "description": "Student exam sessions"
    },
    "/grades/{registrationId}": {
      "schema": "Grade",
      "description": "Student grades collection"
    }
  }
}
